/**
  * @brief  Function implementing the defaultTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartDefaultTask */
void StartDefaultTask(void *argument)
{
  /* USER CODE BEGIN 5 */
  /* Infinite loop */
  for(;;)
  {
	  if(Initilize_active == 1 && pwm_active == 0){

		  HAL_GPIO_WritePin(ENBL_GPIO_Port, ENBL_Pin, GPIO_PIN_RESET);
		  HAL_GPIO_WritePin(I1_GPIO_Port, I1_Pin, GPIO_PIN_RESET);
		  HAL_GPIO_WritePin(I2_GPIO_Port, I2_Pin, GPIO_PIN_RESET);
		  HAL_GPIO_WritePin(DIR_GPIO_Port, DIR_Pin, GPIO_PIN_SET);

		  HAL_TIM_PWM_Start_IT(&htim9, TIM_CHANNEL_1);
		  pwm_active = 1;

	  }
	  else if(Initilize_active == 0){
		  osThreadSuspend(NULL);
	  }

    osDelay(1);
  }
  // incase we leave the foreverloop
  osThreadTerminate(NULL);


  /* USER CODE END 5 */
}

