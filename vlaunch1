	// Callback - called every PWM period (in stm32f4xx_it.c or main.c)
	void HAL_TIM_PWM_PulseFinishedCallback(TIM_HandleTypeDef *htim) {
		if (htim->Instance == TIM9) {
			pulse_count++;

			if (pulse_count >= target_pulses) {
				HAL_TIM_PWM_Stop_IT(&htim9, TIM_CHANNEL_1);
				HAL_GPIO_WritePin(GPIOE, GPIO_PIN_10, GPIO_PIN_SET);
				pwm_active = 0;
				/* update global position: forward adds, backward subtracts */
				global_step_count += current_step_direction * (int32_t)target_pulses;
			}
			else if(htim->Instance == TIM_CHANNEL_2){
				stepError = Step2target - Step2Globalcount;
				Step2Globalcount++;
				uint16_t raw2pulse = abs(stepError);
				if(pulse2_count >= raw2pulse){
					HAL_TIM_PWM_Stop_IT(&htim9, TIM_CHANNEL_2);
					HAL_GPIO_WritePin(ENBL2_GPIO_port, ENBL2_Pin, GPIO_PIN_SET);
					steps2done = 1;
				}
			}
		}
	}

	void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
	{
	    if (huart->Instance == USART1)
	    {
	        /* Store in buffer (with bounds check) */
	        if (rx_len < RX_BUF_SIZE)
	            rx_buf[rx_len++] = rx_byte;

	        /* Echo back only printable characters so terminal display stays clean */
	        if (rx_byte >= 32 && rx_byte < 127)
	            HAL_UART_Transmit(&huart1, &rx_byte, 1, 50);

	        /* On Enter: flag line ready for parse task */
	        if (rx_byte == '\r' || rx_byte == '\n') {
	            line_len = rx_len;
	            line_ready = 1;
	            rx_len = 0;
	            //relliese semaphore safley from a ISR
	            BaseType_t xHigherPriorityTaskWoken = pdFALSE;
	            xSemaphoreGiveFromISR((SemaphoreHandle_t)ParseCharHandle, &xHigherPriorityTaskWoken);
	            portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
	        }

	        HAL_UART_Receive_IT(&huart1, &rx_byte, 1);
	    }
	}




