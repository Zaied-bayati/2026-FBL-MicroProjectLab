/* USER CODE BEGIN Header_XaxisMotor */
/**
* @brief Function implementing the myTask06 thread.
* @param argument: Not used
* @retval None
*/
/* USER CODE END Header_XaxisMotor */
void XaxisMotor(void *argument)
{
  /* USER CODE BEGIN XaxisMotor */
  for(;;)
  {
	  uint16_t deg;
	  if (osMessageQueueGet(myQueue01Handle, &deg, NULL, osWaitForever) != osOK)
		  continue;

	  /* If calibration in progress, skip this move so we don't fight the calibration motor */
	  if (x_calibrating) {
		  debug_log("XaxisMotor", "skip move calibrating", "E", 0);
		  continue;
	  }

	  int32_t target_deg = (int32_t)deg;
	  HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);
	  int32_t integral_deg = 0;   /* degree*ms */
	  int32_t prev_error_deg = 0;

	  {
		  int32_t pos = get_x_encoder();
		  int32_t pos_deg = pos / (int32_t)X_COUNTS_PER_DEGREE;
		  x_current_position = pos;
		  char buf[64];
		  int n = snprintf(buf, sizeof(buf), "Position: %ld deg  Target: %ld deg\r\n",
			  (long)pos_deg, (long)target_deg);
		  if (n > 0 && (size_t)n < sizeof(buf))
			  HAL_UART_Transmit(&huart1, (uint8_t *)buf, (uint16_t)n, 50);
	  }

	  while (1) {
		  if (x_calibrating) {
			  x_axis_set_motor(0);
			  break;
		  }
		  int32_t pos = get_x_encoder();
		  x_current_position = pos;
		  int32_t current_deg = pos / (int32_t)X_COUNTS_PER_DEGREE;
		  int32_t error_deg = target_deg - current_deg;

		  if (error_deg < 0) {
			  if (-error_deg <= (int32_t)X_PID_DEADBAND_DEG) break;
		  } else {
			  if (error_deg <= (int32_t)X_PID_DEADBAND_DEG) break;
		  }

		  integral_deg += error_deg * X_PID_DT_MS;
		  if (integral_deg >  X_PID_INT_MAX) integral_deg =  X_PID_INT_MAX;
		  if (integral_deg < -X_PID_INT_MAX) integral_deg = -X_PID_INT_MAX;

		  int32_t derivative_deg = (error_deg - prev_error_deg) / X_PID_DT_MS;
		  prev_error_deg = error_deg;

		  /* PID output in degree units; scale to motor (counts) for same response as before */
		  int32_t pid_out_deg = (X_PID_KP * error_deg) / 50
							   + (X_PID_KI * integral_deg) / 50
							   + (X_PID_KD * derivative_deg) / 50;
		  int32_t motor_out = pid_out_deg * (int32_t)X_COUNTS_PER_DEGREE / 50;

		  if (motor_out >  X_PID_OUT_MAX) motor_out =  X_PID_OUT_MAX;
		  if (motor_out < -X_PID_OUT_MAX) motor_out = -X_PID_OUT_MAX;

		  x_axis_set_motor((int32_t)X_PID_MOTOR_SIGN * motor_out);
		  osDelay(X_PID_DT_MS);
	  }

	  x_axis_set_motor(0);

	  if (!x_calibrating) {
		  int32_t pos = get_x_encoder();
		  int32_t pos_deg = pos / (int32_t)X_COUNTS_PER_DEGREE;
		  char buf[64];
		  int n = snprintf(buf, sizeof(buf), "Done. Position: %ld deg\r\n", (long)pos_deg);
		  if (n > 0 && (size_t)n < sizeof(buf))
			  HAL_UART_Transmit(&huart1, (uint8_t *)buf, (uint16_t)n, 500);
	  }

    osDelay(1);
  }
  /* USER CODE END XaxisMotor */
}

