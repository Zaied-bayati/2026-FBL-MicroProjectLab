			HAL_UART_Transmit(&huart1, (uint8_t *)buf, (uint16_t)n, 100);
	}
	// #endregion agent log

	//pulsing helper function
	void StartPulses(uint32_t num_pulses) {
		HAL_GPIO_WritePin(ENBL_GPIO_Port, ENBL_Pin, GPIO_PIN_RESET);
		target_pulses = num_pulses;
		pwm_active = 1;
		pulse_count = 0;
		HAL_TIM_PWM_Start_IT(&htim9, TIM_CHANNEL_1);


	}

	/* Read X-axis encoder position (TIM2 in encoder mode). */
	static int32_t get_x_encoder(void) {
		return (int32_t)__HAL_TIM_GET_COUNTER(&htim2);
	}

	/* Set X-axis motor from PID output: positive = right (PC8/TIM3_CH3), negative = left (PB4/TIM3_CH1), 0 = stop. */
	static void x_axis_set_motor(int32_t pid_out) {
		HAL_TIM_PWM_Stop(&htim3, TIM_CHANNEL_1);
		HAL_TIM_PWM_Stop(&htim3, TIM_CHANNEL_3);
		if (pid_out == 0) return;
		uint32_t duty = (uint32_t)(pid_out < 0 ? -pid_out : pid_out);
		if (duty > X_TIM3_PERIOD) duty = X_TIM3_PERIOD;
		if (pid_out > 0) {
			__HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_3, duty);
			HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_3);
		} else {
			__HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, duty);
			HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1);
		}
	}


