/* USER CODE BEGIN Header_ParseCommand */
/**
* @brief Function implementing the Usart thread.
* @param argument: Not used
* @retval None
*/
/* USER CODE END Header_ParseCommand */
void ParseCommand(void *argument)
{
  /* USER CODE BEGIN ParseCommand */
  /* Infinite loop */
  for(;;)
  {

	osSemaphoreAcquire(ParseCharHandle, osWaitForever);

	/* Copy length (ISR may update line_len for next line) */
	uint16_t len = line_len;
	line_ready = 0;
	char cmd[RX_BUF_SIZE];
	// check if launch command is sent
	if (len > 0 && len < RX_BUF_SIZE) {
		memcpy(cmd, rx_buf, len);
	    cmd[len] = '\0';
	    /* Command "L": trigger launch sequence */
	    if (len >= 1 && cmd[0] == 'L' &&
	        (len == 1 || cmd[1] == '\r' || cmd[1] == '\n')) {
	        osSemaphoreRelease(StartMHandle);
	        const char ack[] = "Launch\r\n";
	        HAL_UART_Transmit(&huart1, (const uint8_t *)ack, sizeof(ack) - 1, 50);
	    }
	    /* X-axis: "X0" = calibrate (turn left until IR, set 0°); "X<deg>" = go to angle 1..180° */
	    else if (len >= 2 && cmd[0] == 'X') {
	        char *start = (char *)&cmd[1];
	        while (start < (char *)&cmd[len] && (*start == ' ' || *start == '\t'))
	            start++;
	        if (start < (char *)&cmd[len]) {
	            char *endptr;
	            long val = strtol(start, &endptr, 10);
	            debug_log("ParseCommand:X", "X branch parsed", "A", (int32_t)val);
	            if (endptr > start) {
	                if (val == 0) {
	                    /* X0: run calibration; set flag so PID does not fight, then start sequence */
	                    x_calibrating = 1;
	                    osSemaphoreRelease(beginxinitHandle);
	                    debug_log("ParseCommand:X0", "released beginxinit", "A", 0);
	                } else {
	                    if (val < (long)X_DEGREE_MIN) val = (long)X_DEGREE_MIN;
	                    if (val > (long)X_DEGREE_MAX) val = (long)X_DEGREE_MAX;
	                    uint16_t deg = (uint16_t)val;
	                    (void)osMessageQueuePut(myQueue01Handle, &deg, 0, 0);
	                }
	            }
	        }
	    }

	}
	/* Always start device output on a new line and show prompt so CLI clears */
	{
		const char prompt[] = "\r\n> ";
		HAL_UART_Transmit(&huart1, (const uint8_t *)prompt, sizeof(prompt) - 1, 50);
	}
    osDelay(1);
