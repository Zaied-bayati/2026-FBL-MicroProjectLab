/* USER CODE BEGIN Header_ReadXIR */
/**
* @brief Function implementing the myTask08 thread.
* @param argument: Not used
* @retval None
*/
/* USER CODE END Header_ReadXIR */
void ReadXIR(void *argument)
{
  /* USER CODE BEGIN ReadXIR */
  for(;;)
  {
	  osSemaphoreAcquire(irxpollingHandle, osWaitForever);
	  debug_log("ReadXIR", "got irxpolling", "C", 0);

	  uint32_t elapsed_ms = 0;
	  while (HAL_GPIO_ReadPin(XAIR_GPIO_Port, XAIR_Pin) != XAIR_AT_HOME_LEVEL) {
		  osDelay(4);
		  elapsed_ms++;
		  if (elapsed_ms >= (uint32_t)X_CAL_TIMEOUT_MS)
			  break;
	  }

	  HAL_TIM_PWM_Stop(&htim3, TIM_CHANNEL_1);
	  HAL_TIM_PWM_Stop(&htim3, TIM_CHANNEL_3);

	  debug_log("ReadXIR", "exit wait", "C", elapsed_ms >= (uint32_t)X_CAL_TIMEOUT_MS ? -1 : (int32_t)(uint32_t)elapsed_ms);

	  if (elapsed_ms >= (uint32_t)X_CAL_TIMEOUT_MS) {
		  const char msg[] = "Calibration timeout\r\n";
		  HAL_UART_Transmit(&huart1, (const uint8_t *)msg, sizeof(msg) - 1, 100);
	  } else {
		  __HAL_TIM_SET_COUNTER(&htim2, 0);
		  XDegree = 0;
	  }
	  x_calibrating = 0;
	  debug_log("ReadXIR", "cleared x_calibrating", "E", 0);

    osDelay(3);
  }
  /* USER CODE END ReadXIR */
}

